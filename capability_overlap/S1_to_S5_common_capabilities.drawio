        <mxCell id="14" parent="1" vertex="1" value="&lt;b&gt;Workflow run engine&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;MDAO tools call GoF — not vice versa&lt;/font&gt;&lt;br&gt;&lt;font style='font-size:9px;color:#333'&gt;&lt;i&gt;GoF builds &amp; operates this&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B8D4EF;strokeColor=#005AAB;fontStyle=1">
