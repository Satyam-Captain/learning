        <mxCell id="flow" parent="1" vertex="1" value="&lt;b&gt;Typical engineer path:&lt;/b&gt; Browser -&amp;gt; Open OnDemand (auth via Keystone) -&amp;gt; files on Manila / jobs to Slurm -&amp;gt; GoF APIs add references, MDAC, run IDs, SPDM staging. &lt;b&gt;Typical automation path:&lt;/b&gt; CI/MDAO -&amp;gt; GoF workflow API -&amp;gt; Slurm batch -&amp;gt; results as references back to SPDM." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#CC9900;fontSize=11;align=left;">
          <mxGeometry x="40" y="1380" width="2320" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="map" parent="1" vertex="1" value="&lt;b&gt;Workshop mapping:&lt;/b&gt; S1 data -&amp;gt; Manila + GoF cache/MDAC | S2 dev -&amp;gt; OOD + registry + GoF env | S3 runs -&amp;gt; OOD/Slurm + GoF run API | S4 workflows -&amp;gt; GoF engine + Heat optional | S5 MDAO -&amp;gt; Slurm adapter (separate) | S6 ML -&amp;gt; Magnum/K8s or Slurm GPU | S7 federation -&amp;gt; separate column" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;">
          <mxGeometry x="40" y="1450" width="2320" height="45" as="geometry"/>
